# ──────────────────────────────────────────────────────────────
# ASTRA SANDBOX — Environment Variables
# Copy this file to .env for local dev. NEVER commit the real .env!
# On Vercel: add these in Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────

# Groq API Key (preferred — fast & free tier available)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (fallback if Groq key is not set)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
